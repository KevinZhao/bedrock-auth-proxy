{
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_REGION": "ap-northeast-1",
    "ANTHROPIC_BEDROCK_BASE_URL": "http://127.0.0.1:8888",
    "CLAUDE_CODE_SKIP_BEDROCK_AUTH": "1",
    "ANTHROPIC_MODEL": "global.anthropic.claude-opus-4-6-v1[1m]",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",

    "UPSTREAM_ENDPOINT": "https://runway.devops.rednote.life/openai/bedrock_runtime",
    "AUTH_HEADER_NAME": "token",
    "AUTH_HEADER_VALUE": "your-auth-token"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LSP",
      "Bash(git *)",
      "Bash(go *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(git push * --force)",
      "Bash(git reset --hard)"
    ]
  },
  "language": "chinese",
  "enableAgentTeams": true,
  "alwaysThinkingEnabled": true
}
